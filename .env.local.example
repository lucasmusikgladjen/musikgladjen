# Make webhook URL for student form submissions
NEXT_PUBLIC_WEBHOOK_URL=https://hook.eu1.make.com/your-webhook-id

# Airtable API key (for job application submissions)
AIRTABLE_API_KEY=your_airtable_api_key_here

# Optional: GTM container ID
NEXT_PUBLIC_GTM_ID=GTM-XXXXXXX

# Meta Conversions API access token (server-side, never expose to browser)
META_ACCESS_TOKEN=your_meta_access_token_here
